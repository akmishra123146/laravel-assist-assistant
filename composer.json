{
    "name": "laravel-assist/assistant",
    "description": "AI-powered code analysis, security auditing, and health reporting for Laravel applications",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "code-analysis",
        "security",
        "performance",
        "ai",
        "code-quality",
        "health-report"
    ],
    "homepage": "https://github.com/laravel-assist/assistant",
    "authors": [
        {
            "name": "Laravel Assist",
            "email": "hello@laravel-assist.dev"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/filesystem": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.5|^11.5",
        "phpstan/phpstan": "^1.10",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "LaravelAssist\\Assistant\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaravelAssist\\Assistant\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelAssist\\Assistant\\AssistantServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
